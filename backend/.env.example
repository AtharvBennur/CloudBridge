# ============================================================
# CloudBridge Backend Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ============================================================
# Flask Configuration
# ============================================================
# [REQUIRED] Environment: development, testing, or production
FLASK_ENV=development

# [REQUIRED] Secret key for session encryption.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-local-env-use-openssl-rand-hex-32

# [REQUIRED] Database connection string (PostgreSQL recommended for production)
DATABASE_URL=sqlite:///cloudbridge.db

# [REQUIRED] Host to bind the Flask server to
HOST=0.0.0.0

# [REQUIRED] Port for the Flask server
PORT=5000

# [REQUIRED] Enable/disable debug mode (never enable in production)
FLASK_DEBUG=true

# [REQUIRED] CORS allowed origins (comma-separated frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# [REQUIRED] Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# [OPTIONAL] File path for log output. When set, logs are written to this file
# in addition to the console. Example: logs/cloudbridge.log
LOG_FILE=

# ============================================================
# Test Database Configuration
# ============================================================
# [OPTIONAL] Override DATABASE_URL when FLASK_ENV=testing.
# Defaults to sqlite:///:memory: if not set.
TEST_DATABASE_URL=

# ============================================================
# AWS Cognito Configuration
# ============================================================
# [REQUIRED for production] AWS region where Cognito is deployed
COGNITO_REGION=

# [REQUIRED for production] Cognito User Pool ID (e.g. us-east-1_AbCdEfGhI)
COGNITO_USER_POOL_ID=

# [REQUIRED for production] Cognito App Client ID
COGNITO_CLIENT_ID=

# [OPTIONAL] Cognito Identity Pool ID (needed for AWS credential federation)
COGNITO_IDENTITY_POOL_ID=

# ============================================================
# AWS Credentials Configuration
# ============================================================
# [REQUIRED for production] AWS Access Key ID for CloudBridge control plane
# (used for STS AssumeRole to customer accounts)
AWS_ACCESS_KEY_ID=

# [REQUIRED for production] AWS Secret Access Key for CloudBridge control plane
AWS_SECRET_ACCESS_KEY=

# [REQUIRED] Default AWS region
AWS_DEFAULT_REGION=us-east-1

# [REQUIRED for production] CloudBridge AWS Account ID (for STS AssumeRole trust policy)
CLOUDBRIDGE_AWS_ACCOUNT_ID=

# ============================================================
# AWS ECS Configuration
# ============================================================
# [OPTIONAL] ECS Cluster Name for migration workers
ECS_CLUSTER_NAME=cloudbridge-migration-cluster

# [OPTIONAL] ECS Task Definition for migration workers
ECS_TASK_DEFINITION=cloudbridge-migration-task

# [OPTIONAL] CloudWatch Log Group for worker logs
CLOUDWATCH_LOG_GROUP=/aws/ecs/cloudbridge-migration-workers

# ============================================================
# AWS Secrets Manager Configuration
# ============================================================
# [OPTIONAL] Prefix for secrets stored in Secrets Manager
SECRETS_PREFIX=cloudbridge/

# [OPTIONAL] TTL for cached secrets in seconds
SECRETS_CACHE_TTL=300

# ============================================================
# Google OAuth Configuration
# ============================================================
# [OPTIONAL] Google OAuth Client ID (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=

# [OPTIONAL] Google OAuth Client Secret (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================================
# SMTP Configuration (for email notifications)
# ============================================================
# [OPTIONAL] SMTP server host
SMTP_HOST=smtp.gmail.com

# [OPTIONAL] SMTP server port
SMTP_PORT=587

# [OPTIONAL] Enable TLS for SMTP connections
SMTP_USE_TLS=true

# [OPTIONAL] SMTP authentication username
SMTP_USERNAME=

# [OPTIONAL] SMTP authentication password (use app password for Gmail)
SMTP_PASSWORD=

# [OPTIONAL] Sender email address
SMTP_FROM_ADDRESS=noreply@cloudbridge.io

# [OPTIONAL] Sender display name
SMTP_FROM_NAME=CloudBridge

# ============================================================
# Slack Configuration (for Slack notifications)
# ============================================================
# [OPTIONAL] Slack incoming webhook URL for alert notifications
SLACK_WEBHOOK_URL=

# [OPTIONAL] Slack channel to post alerts to
SLACK_CHANNEL=#cloudbridge-alerts

# [OPTIONAL] Slack bot username for webhook posts
SLACK_USERNAME=CloudBridge

# ============================================================
# Webhook Configuration (for custom webhooks)
# ============================================================
# [OPTIONAL] Custom webhook URL for third-party integrations
WEBHOOK_URL=

# [OPTIONAL] HMAC secret for webhook signature verification
WEBHOOK_SECRET=

# ============================================================
# WebSocket Configuration
# ============================================================
# [OPTIONAL] Message queue URL for distributed Socket.IO deployments
# (e.g. Redis or RabbitMQ URL). Leave empty for in-memory mode.
WEBSOCKET_MESSAGE_QUEUE_URL=

# [OPTIONAL] WebSocket CORS allowed origins
WEBSOCKET_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================================
# Migration Configuration
# ============================================================
# [OPTIONAL] Default batch size for data migration
MIGRATION_BATCH_SIZE=10000

# [OPTIONAL] Default number of parallel migration workers
MIGRATION_PARALLEL_WORKERS=4

# [OPTIONAL] Checkpoint creation interval in seconds
MIGRATION_CHECKPOINT_INTERVAL=60

# [OPTIONAL] Maximum retry attempts for failed migration operations
MIGRATION_MAX_RETRIES=3

# [OPTIONAL] Timeout for migration operations in seconds
MIGRATION_TIMEOUT=3600

# ============================================================
# CDC (Change Data Capture) Configuration
# ============================================================
# [OPTIONAL] CDC replication slot name prefix
CDC_SLOT_PREFIX=cloudbridge_cdc_

# [OPTIONAL] CDC WAL retention period in hours
CDC_WAL_RETENTION_HOURS=24

# [OPTIONAL] CDC replication lag threshold in seconds (triggers alerts)
CDC_LAG_THRESHOLD_SECONDS=30

# ============================================================
# Schema Drift Configuration
# ============================================================
# [OPTIONAL] Schema drift check interval in seconds
SCHEMA_DRIFT_CHECK_INTERVAL=300

# [OPTIONAL] Auto-approve safe schema changes (non-breaking)
SCHEMA_DRIFT_AUTO_APPROVE_SAFE=true

# ============================================================
# Observability Configuration
# ============================================================
# [OPTIONAL] Enable CloudWatch metrics export
CLOUDWATCH_METRICS_ENABLED=true

# [OPTIONAL] CloudWatch metrics namespace
CLOUDWATCH_METRICS_NAMESPACE=CloudBridge

# [OPTIONAL] Enable audit logging to database
AUDIT_LOGGING_ENABLED=true

# [OPTIONAL] Audit log retention period in days
AUDIT_LOG_RETENTION_DAYS=90

# ============================================================
# Rollback Configuration
# ============================================================
# [OPTIONAL] Automatically create checkpoints before migrations
ROLLBACK_AUTO_CHECKPOINT=true

# [OPTIONAL] Checkpoint retention period in days
CHECKPOINT_RETENTION_DAYS=30

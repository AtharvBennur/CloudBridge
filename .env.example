# ============================================================
# CloudBridge Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials
# Never commit .env to version control

# ============================================================
# Docker Configuration
# ============================================================
COMPOSE_PROJECT_NAME=cloudbridge
BACKEND_PORT=5000
FRONTEND_PORT=5173

# ============================================================
# API Configuration
# ============================================================
# Backend API base URL
VITE_API_BASE_URL=http://localhost:5000
# WebSocket base URL (auto-derived from API_BASE_URL if not set)
VITE_WS_BASE_URL=ws://localhost:5000

# ============================================================
# Google OAuth Configuration
# ============================================================
# Google OAuth Client ID (from Google Cloud Console)
# Get this from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
# Google OAuth Client Secret (from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# ============================================================
# Flask Backend Configuration
# ============================================================
# Environment: development, testing, or production
FLASK_ENV=development
# Secret key for session encryption - generate with: openssl rand -hex 32
SECRET_KEY=generate-with-openssl-rand-hex-32
# Database connection string (PostgreSQL recommended for production)
DATABASE_URL=sqlite:///cloudbridge.db
# Host to bind the Flask server to
HOST=0.0.0.0
# Port for the Flask server
PORT=5000
# Enable/disable debug mode (never enable in production)
FLASK_DEBUG=true
# CORS allowed origins (comma-separated frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# AWS Configuration
# ============================================================
# AWS Access Key ID for CloudBridge control plane
AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS Secret Access Key for CloudBridge control plane
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Default AWS region
AWS_DEFAULT_REGION=us-east-1
# CloudBridge AWS Account ID (for STS AssumeRole trust policy)
CLOUDBRIDGE_AWS_ACCOUNT_ID=your-aws-account-id
# AWS ECS Cluster Name for migration workers
ECS_CLUSTER_NAME=cloudbridge-migration-cluster
# AWS ECS Task Definition for migration workers
ECS_TASK_DEFINITION=cloudbridge-migration-task
# AWS CloudWatch Log Group for worker logs
CLOUDWATCH_LOG_GROUP=/aws/ecs/cloudbridge-migration-workers

# ============================================================
# AWS Secrets Manager Configuration
# ============================================================
# Prefix for secrets stored in Secrets Manager
SECRETS_PREFIX=cloudbridge/
# TTL for cached secrets in seconds
SECRETS_CACHE_TTL=300

# ============================================================
# SMTP Configuration (for email notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@cloudbridge.io
SMTP_FROM_NAME=CloudBridge

# ============================================================
# Slack Configuration (for Slack notifications)
# ============================================================
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_CHANNEL=#cloudbridge-alerts
SLACK_USERNAME=CloudBridge

# ============================================================
# Webhook Configuration (for custom webhooks)
# ============================================================
WEBHOOK_URL=your-webhook-url
WEBHOOK_SECRET=your-webhook-secret

# ============================================================
# WebSocket Configuration
# ============================================================
# WebSocket message queue URL (for distributed deployments)
WEBSOCKET_MESSAGE_QUEUE_URL=
# WebSocket CORS allowed origins
WEBSOCKET_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================================
# Migration Configuration
# ============================================================
# Default batch size for data migration
MIGRATION_BATCH_SIZE=10000
# Default number of parallel workers
MIGRATION_PARALLEL_WORKERS=4
# Checkpoint interval in seconds
MIGRATION_CHECKPOINT_INTERVAL=60
# Maximum retry attempts for failed operations
MIGRATION_MAX_RETRIES=3
# Timeout for migration operations in seconds
MIGRATION_TIMEOUT=3600

# ============================================================
# CDC Configuration
# ============================================================
# CDC replication slot name prefix
CDC_SLOT_PREFIX=cloudbridge_cdc_
# CDC WAL retention period in hours
CDC_WAL_RETENTION_HOURS=24
# CDC replication lag threshold in seconds
CDC_LAG_THRESHOLD_SECONDS=30

# ============================================================
# Schema Drift Configuration
# ============================================================
# Schema drift check interval in seconds
SCHEMA_DRIFT_CHECK_INTERVAL=300
# Auto-approve safe schema changes
SCHEMA_DRIFT_AUTO_APPROVE_SAFE=true

# ============================================================
# Observability Configuration
# ============================================================
# Enable CloudWatch metrics export
CLOUDWATCH_METRICS_ENABLED=true
# CloudWatch metrics namespace
CLOUDWATCH_METRICS_NAMESPACE=CloudBridge
# Enable audit logging
AUDIT_LOGGING_ENABLED=true
# Audit log retention period in days
AUDIT_LOG_RETENTION_DAYS=90

# ============================================================
# Rollback Configuration
# ============================================================
# Enable automatic checkpoint creation
ROLLBACK_AUTO_CHECKPOINT=true
# Checkpoint retention period in days
CHECKPOINT_RETENTION_DAYS=30

# ============================================================
# Application Configuration
# ============================================================
# Application name
VITE_APP_NAME=CloudBridge
# Application version
VITE_APP_VERSION=1.0.0
# Enable/disable debug mode (never enable in production)
VITE_DEBUG=true

# ============================================================
# Feature Flags
# ============================================================
# Enable CDC feature
VITE_FEATURE_CDC=true
# Enable Schema Drift feature
VITE_FEATURE_SCHEMA_DRIFT=true
# Enable Approval Workflow feature
VITE_FEATURE_APPROVALS=true
# Enable ECS feature
VITE_FEATURE_ECS=true
# Enable Observability feature
VITE_FEATURE_OBSERVABILITY=true
# Enable Notifications feature
VITE_FEATURE_NOTIFICATIONS=true
# Enable Rollback feature
VITE_FEATURE_ROLLBACK=true

# ============================================================
# UI Configuration
# ============================================================
# Default theme: light, dark, or system
VITE_DEFAULT_THEME=system
# Enable/disable animations
VITE_ENABLE_ANIMATIONS=true
# Enable/disable telemetry (anonymous usage data)
VITE_ENABLE_TELEMETRY=false
